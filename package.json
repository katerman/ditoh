{
	"name": "ditoh-monorepo",
	"packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
	"private": true,
	"description": "Monorepo for Ditoh",
	"author": "Kevin Reynolds",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/katerman/ditoh.git"
	},
	"scripts": {
		"lint": "pnpm exec biome check --write",
		"test": "pnpm --filter ditoh run test run",
		"coverage": "pnpm --filter ditoh run coverage",
		"build": "pnpm --filter ditoh run build",
		"build:watch": "pnpm --filter ditoh run build:watch",
		"type:check": "pnpm --filter ditoh run type:check",
		"publish-packages": "cp README.md LICENSE.md packages/ditoh/ && changeset publish && rm packages/ditoh/README.md packages/ditoh/LICENSE.md",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,md,json}": [
			"pnpm exec biome check --write"
		],
		"*.ts": [
			"pnpm test run"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/node": "^22.19.19",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5"
	}
}
